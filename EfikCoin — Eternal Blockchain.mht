@charset "utf-8";

:root { --primary: #7c3aed; --primary-light: #9f67ff; --primary-dark: #5b21b6; --accent: #06b6d4; --accent2: #f59e0b; --green: #10b981; --red: #ef4444; --orange: #f97316; --bg-dark: #0a0a0f; --bg-card: rgba(255,255,255,0.04); --bg-card-hover: rgba(255,255,255,0.07); --border: rgba(255,255,255,0.08); --border-bright: rgba(124,58,237,0.4); --text: #f1f5f9; --text-muted: #94a3b8; --text-dim: #64748b; --glass: rgba(15,15,30,0.7); --shadow: 0 8px 32px rgba(0,0,0,0.4); --radius: 16px; --radius-sm: 10px; --font-head: 'Orbitron', monospace; --font-body: 'Inter', sans-serif; }

*, ::before, ::after { box-sizing: border-box; margin: 0px; padding: 0px; }

html { scroll-behavior: smooth; }

body { font-family: var(--font-body); background: var(--bg-dark); color: var(--text); overflow-x: hidden; min-height: 100vh; }

#particleCanvas { position: fixed; top: 0px; left: 0px; width: 100%; height: 100%; z-index: 0; pointer-events: none; }

::-webkit-scrollbar { width: 6px; }

::-webkit-scrollbar-track { background: var(--bg-dark); }

::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 3px; }

#navbar { position: fixed; top: 0px; left: 0px; right: 0px; z-index: 100; background: rgba(10, 10, 15, 0.85); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); padding: 0px 2rem; transition: 0.3s; }

.nav-container { max-width: 1400px; margin: 0px auto; display: flex; align-items: center; height: 70px; gap: 2rem; }

.nav-logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; flex-shrink: 0; }

.logo-icon { font-size: 1.8rem; background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; background-clip: text; -webkit-text-fill-color: transparent; font-family: var(--font-head); }

.logo-text { font-family: var(--font-head); font-size: 1.2rem; font-weight: 700; color: var(--text); letter-spacing: 1px; }

.logo-tag { font-size: 0.55rem; font-family: var(--font-head); color: var(--accent2); border: 1px solid var(--accent2); padding: 2px 6px; border-radius: 4px; letter-spacing: 2px; margin-left: 4px; }

.nav-links { display: flex; list-style: none; gap: 0.3rem; flex: 1 1 0%; justify-content: center; }

.nav-link { text-decoration: none; color: var(--text-muted); font-size: 0.85rem; font-weight: 500; padding: 0.45rem 0.9rem; border-radius: 8px; transition: 0.2s; letter-spacing: 0.3px; }

.nav-link:hover, .nav-link.active { color: var(--text); background: var(--bg-card-hover); }

.nav-link.active { color: var(--primary-light); }

.nav-actions { display: flex; align-items: center; gap: 1rem; flex-shrink: 0; }

.price-ticker { display: flex; align-items: center; gap: 0.4rem; background: var(--bg-card); border: 1px solid var(--border); padding: 0.4rem 0.8rem; border-radius: 8px; font-size: 0.82rem; }

.ticker-label { color: var(--text-dim); font-weight: 600; }

.ticker-price { color: var(--text); font-weight: 700; font-family: var(--font-head); font-size: 0.78rem; }

.ticker-change.positive { color: var(--green); }

.ticker-change.negative { color: var(--red); }

.btn-connect { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: rgb(255, 255, 255); border: none; padding: 0.5rem 1.2rem; border-radius: 10px; font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: 0.2s; display: flex; align-items: center; gap: 0.4rem; white-space: nowrap; }

.btn-connect:hover { transform: translateY(-1px); box-shadow: rgba(124, 58, 237, 0.4) 0px 4px 15px; }

.hamburger { display: none; flex-direction: column; gap: 4px; background: none; border: none; cursor: pointer; padding: 4px; }

.hamburger span { display: block; width: 22px; height: 2px; background: var(--text); border-radius: 2px; transition: 0.3s; }

.glass-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; backdrop-filter: blur(10px); }

.section { position: relative; z-index: 1; min-height: 100vh; padding: 6rem 2rem 4rem; }

.dashboard-section { padding: 7rem 2rem 4rem; max-width: 1400px; margin: 0px auto; }

.hero-section { display: flex; align-items: center; justify-content: space-between; gap: 3rem; max-width: 1400px; margin: 0px auto; padding-top: 5rem; }

.hero-content { flex: 1 1 0%; max-width: 600px; }

.hero-badge { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(6, 182, 212, 0.1); border: 1px solid rgba(6, 182, 212, 0.3); color: var(--accent); padding: 0.4rem 1rem; border-radius: 50px; font-size: 0.82rem; font-weight: 600; margin-bottom: 1.5rem; letter-spacing: 0.5px; }

.badge-dot { width: 8px; height: 8px; background: var(--accent); border-radius: 50%; animation: 1.5s ease 0s infinite normal none running pulse; }

@keyframes pulse { 
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.3); }
}

.hero-title { font-family: var(--font-head); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 900; line-height: 1.1; margin-bottom: 1.2rem; letter-spacing: -1px; }

.gradient-text { background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; -webkit-text-fill-color: transparent; background-clip: text; }

.hero-subtitle { color: var(--text-muted); font-size: 1.05rem; line-height: 1.7; margin-bottom: 2rem; }

.hero-stats { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 2.5rem; flex-wrap: wrap; }

.stat-item { text-align: center; }

.stat-value { display: block; font-family: var(--font-head); font-size: 1.4rem; font-weight: 700; color: var(--text); }

.stat-label { font-size: 0.75rem; color: var(--text-dim); letter-spacing: 0.5px; }

.stat-divider { width: 1px; height: 40px; background: var(--border); }

.hero-buttons { display: flex; gap: 1rem; flex-wrap: wrap; }

.btn-primary { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: rgb(255, 255, 255); border: none; padding: 0.75rem 1.8rem; border-radius: 12px; font-size: 0.92rem; font-weight: 600; cursor: pointer; transition: 0.2s; display: inline-flex; align-items: center; gap: 0.5rem; }

.btn-primary:hover { transform: translateY(-2px); box-shadow: rgba(124, 58, 237, 0.5) 0px 6px 20px; }

.btn-secondary { background: transparent; color: var(--primary-light); border: 1px solid var(--primary-light); padding: 0.75rem 1.8rem; border-radius: 12px; font-size: 0.92rem; font-weight: 600; cursor: pointer; transition: 0.2s; display: inline-flex; align-items: center; gap: 0.5rem; }

.btn-secondary:hover { background: rgba(124, 58, 237, 0.1); transform: translateY(-2px); }

.btn-success { background: linear-gradient(135deg, rgb(5, 150, 105), rgb(16, 185, 129)); color: rgb(255, 255, 255); border: none; padding: 0.75rem 1.8rem; border-radius: 12px; font-size: 0.92rem; font-weight: 600; cursor: pointer; transition: 0.2s; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; }

.btn-success:hover { transform: translateY(-2px); box-shadow: rgba(16, 185, 129, 0.4) 0px 6px 20px; }

.btn-danger { background: linear-gradient(135deg, rgb(185, 28, 28), rgb(239, 68, 68)); color: rgb(255, 255, 255); border: none; padding: 0.75rem 1.8rem; border-radius: 12px; font-size: 0.92rem; font-weight: 600; cursor: pointer; transition: 0.2s; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; }

.btn-danger:hover { transform: translateY(-2px); box-shadow: rgba(239, 68, 68, 0.4) 0px 6px 20px; }

.btn-ghost { background: transparent; color: var(--text-muted); border: 1px solid var(--border); padding: 0.75rem 1.8rem; border-radius: 12px; font-size: 0.92rem; font-weight: 600; cursor: pointer; transition: 0.2s; }

.btn-ghost:hover { background: var(--bg-card); }

.full-width { width: 100%; justify-content: center; }

.hero-visual { flex-shrink: 0; display: flex; align-items: center; justify-content: center; }

.coin-orbit { position: relative; width: 380px; height: 380px; display: flex; align-items: center; justify-content: center; }

.orbit-ring { position: absolute; border-radius: 50%; border: 1px solid; animation: auto linear 0s infinite normal none running spin; }

.ring-1 { width: 160px; height: 160px; border-color: rgba(124, 58, 237, 0.3); animation-duration: 8s; }

.ring-2 { width: 260px; height: 260px; border-color: rgba(6, 182, 212, 0.2); animation-duration: 14s; animation-direction: reverse; }

.ring-3 { width: 360px; height: 360px; border-color: rgba(245, 158, 11, 0.15); animation-duration: 22s; }

@keyframes spin { 
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.orbit-dot { position: absolute; width: 12px; height: 12px; border-radius: 50%; animation: auto linear 0s infinite normal none running spin; }

.dot-1 { width: 180px; height: 180px; border-radius: 50%; display: flex; align-items: flex-start; justify-content: center; animation-duration: 8s; background: transparent; box-shadow: none; }

.dot-1::before { content: ""; width: 12px; height: 12px; background: var(--primary); border-radius: 50%; box-shadow: 0 0 12px var(--primary); margin-top: 0px; }

.dot-2 { background: transparent; box-shadow: none; width: 280px; height: 280px; border-radius: 50%; display: flex; align-items: flex-start; justify-content: center; animation-duration: 14s; animation-direction: reverse; }

.dot-2::before { content: ""; width: 10px; height: 10px; background: var(--accent); border-radius: 50%; box-shadow: 0 0 10px var(--accent); margin-top: 0px; }

.dot-3 { background: transparent; box-shadow: none; width: 370px; height: 370px; border-radius: 50%; display: flex; align-items: flex-start; justify-content: center; animation-duration: 22s; }

.dot-3::before { content: ""; width: 8px; height: 8px; background: var(--accent2); border-radius: 50%; box-shadow: 0 0 8px var(--accent2); margin-top: 0px; }

.coin-center { position: absolute; width: 110px; height: 110px; background: linear-gradient(135deg, var(--primary-dark), var(--primary), var(--accent)); border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; box-shadow: rgba(124, 58, 237, 0.6) 0px 0px 40px, rgba(124, 58, 237, 0.3) 0px 0px 80px; animation: 3s ease-in-out 0s infinite normal none running coinGlow; }

@keyframes coinGlow { 
  0%, 100% { box-shadow: rgba(124, 58, 237, 0.6) 0px 0px 40px, rgba(124, 58, 237, 0.3) 0px 0px 80px; }
  50% { box-shadow: rgba(6, 182, 212, 0.7) 0px 0px 60px, rgba(6, 182, 212, 0.3) 0px 0px 100px; }
}

.coin-face { font-size: 2.5rem; color: rgb(255, 255, 255); font-family: var(--font-head); }

.coin-label { font-family: var(--font-head); font-size: 0.75rem; font-weight: 700; color: rgba(255, 255, 255, 0.8); letter-spacing: 3px; }

.ticker-bar { position: relative; z-index: 2; background: linear-gradient(135deg, rgba(124, 58, 237, 0.15), rgba(6, 182, 212, 0.15)); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 0.6rem 0px; overflow: hidden; }

.ticker-track { display: inline-block; white-space: nowrap; animation: 30s linear 0s infinite normal none running scrollTicker; font-size: 0.8rem; color: var(--text-muted); letter-spacing: 0.5px; }

.ticker-track span:first-child { color: var(--accent2); }

@keyframes scrollTicker { 
  0% { transform: translateX(0px); }
  100% { transform: translateX(-50%); }
}

.features-bar { position: relative; z-index: 2; display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1px; background: var(--border); border-bottom: 1px solid var(--border); }

.feature-card { background: var(--bg-dark); padding: 1.5rem; display: flex; align-items: center; gap: 1rem; cursor: pointer; transition: background 0.2s; }

.feature-card:hover { background: var(--bg-card-hover); }

.feature-icon { width: 44px; height: 44px; border-radius: 12px; background: linear-gradient(135deg, var(--primary), var(--accent)); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; color: rgb(255, 255, 255); flex-shrink: 0; }

.feature-info h3 { font-size: 0.9rem; font-weight: 600; color: var(--text); }

.feature-info p { font-size: 0.75rem; color: var(--text-muted); }

.section-header { margin-bottom: 2.5rem; }

.section-title { font-family: var(--font-head); font-size: 1.8rem; font-weight: 700; display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; }

.section-title i { background-image: ; background-position-x: ; background-position-y: ; background-size: ; background-repeat: ; background-attachment: ; background-origin: ; background-color: ; background-clip: text; -webkit-text-fill-color: transparent; }

.section-sub { color: var(--text-muted); font-size: 0.95rem; }

.wallet-options { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; max-width: 700px; margin: 0px auto 2rem; }

.wallet-option-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 2.5rem 2rem; text-align: center; cursor: pointer; transition: 0.3s; }

.wallet-option-card:hover { border-color: var(--primary); transform: translateY(-4px); box-shadow: rgba(124, 58, 237, 0.2) 0px 8px 30px; }

.wopt-icon { font-size: 2.5rem; color: var(--primary-light); margin-bottom: 1rem; }

.wallet-option-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }

.wallet-option-card p { color: var(--text-muted); font-size: 0.88rem; margin-bottom: 1.5rem; }

.import-form { max-width: 600px; margin: 0px auto; }

.balance-card { background: linear-gradient(135deg, rgba(124, 58, 237, 0.2), rgba(6, 182, 212, 0.15)); border-color: rgba(124, 58, 237, 0.3); margin-bottom: 1.5rem; }

.balance-header { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1.5rem; margin-bottom: 1.5rem; }

.balance-label { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.3rem; }

.balance-main { font-family: var(--font-head); font-size: 2.5rem; font-weight: 700; color: var(--text); }

.balance-efk { font-size: 1rem; color: var(--text-muted); margin-top: 0.2rem; }

.wallet-addr-block { text-align: right; }

.addr-label { font-size: 0.78rem; color: var(--text-dim); margin-bottom: 0.4rem; }

.addr-display { display: flex; align-items: center; gap: 0.5rem; background: rgba(0, 0, 0, 0.3); padding: 0.5rem 0.8rem; border-radius: 8px; border: 1px solid var(--border); font-size: 0.8rem; font-family: monospace; color: var(--accent); }

.copy-btn { background: none; border: none; color: var(--text-muted); cursor: pointer; padding: 2px; transition: color 0.2s; }

.copy-btn:hover { color: var(--primary-light); }

.balance-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

.action-btn { background: rgba(255, 255, 255, 0.07); border: 1px solid var(--border); color: var(--text); padding: 0.5rem 1.1rem; border-radius: 10px; font-size: 0.82rem; font-weight: 600; cursor: pointer; transition: 0.2s; display: flex; align-items: center; gap: 0.4rem; }

.action-btn:hover { background: rgba(124, 58, 237, 0.2); border-color: var(--primary); }

.action-btn.danger:hover { background: rgba(239, 68, 68, 0.15); border-color: var(--red); color: var(--red); }

.wallet-tabs { display: flex; gap: 0.3rem; margin-bottom: 1.5rem; background: var(--bg-card); border: 1px solid var(--border); padding: 0.4rem; border-radius: 12px; overflow-x: auto; }

.tab-btn { background: none; border: none; color: var(--text-muted); padding: 0.55rem 1.2rem; border-radius: 8px; font-size: 0.85rem; font-weight: 500; cursor: pointer; transition: 0.2s; white-space: nowrap; }

.tab-btn:hover { color: var(--text); background: var(--bg-card-hover); }

.tab-btn.active { background: var(--primary); color: rgb(255, 255, 255); font-weight: 600; }

.overview-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }

.overview-card { display: flex; align-items: center; gap: 1rem; }

.ov-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }

.ov-icon.green { background: rgba(16, 185, 129, 0.15); color: var(--green); }

.ov-icon.blue { background: rgba(6, 182, 212, 0.15); color: var(--accent); }

.ov-icon.purple { background: rgba(124, 58, 237, 0.15); color: var(--primary-light); }

.ov-icon.orange { background: rgba(249, 115, 22, 0.15); color: var(--orange); }

.ov-info { display: flex; flex-direction: column; }

.ov-label { font-size: 0.78rem; color: var(--text-muted); }

.ov-value { font-size: 1rem; font-weight: 700; color: var(--text); font-family: var(--font-head); }

.mini-chart-section h3 { font-size: 1rem; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }

.form-group { margin-bottom: 1rem; }

.form-group label { display: block; font-size: 0.82rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem; letter-spacing: 0.3px; }

.form-group input, .form-group select, .form-group textarea { width: 100%; background: rgba(0, 0, 0, 0.3); border: 1px solid var(--border); color: var(--text); padding: 0.75rem 1rem; border-radius: 10px; font-size: 0.92rem; font-family: var(--font-body); transition: border-color 0.2s; outline: none; }

.form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--primary); box-shadow: rgba(124, 58, 237, 0.15) 0px 0px 0px 3px; }

.form-group input::placeholder, .form-group textarea::placeholder { color: var(--text-dim); }

.form-group select option { background: rgb(26, 26, 46); }

.form-row { display: flex; gap: 0.75rem; flex-wrap: wrap; }

.form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

.input-with-tag { position: relative; display: flex; align-items: center; }

.input-with-tag input { padding-right: 3.5rem; }

.input-tag { position: absolute; right: 0.75rem; font-size: 0.75rem; font-weight: 700; color: var(--primary-light); pointer-events: none; }

.divider-text { text-align: center; color: var(--text-dim); font-size: 0.85rem; margin: 0.5rem 0px; }

.form-panel h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem; }

.deposit-methods { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; flex-wrap: wrap; }

.method-btn { background: var(--bg-card); border: 1px solid var(--border); color: var(--text-muted); padding: 0.55rem 1.1rem; border-radius: 10px; font-size: 0.83rem; font-weight: 600; cursor: pointer; transition: 0.2s; display: flex; align-items: center; gap: 0.4rem; }

.method-btn.active, .method-btn:hover { background: rgba(124, 58, 237, 0.15); border-color: var(--primary); color: var(--primary-light); }

.qr-section { display: flex; gap: 2rem; align-items: flex-start; flex-wrap: wrap; }

.qr-code { width: 150px; height: 150px; background: rgba(0, 0, 0, 0.3); border: 1px solid var(--border); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

.qr-placeholder { text-align: center; color: var(--text-dim); }

.qr-placeholder i { font-size: 3rem; display: block; margin-bottom: 0.3rem; }

.qr-placeholder span { font-size: 0.75rem; }

.qr-info { flex: 1 1 0%; min-width: 200px; }

.qr-addr-label { font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.5rem; }

.qr-address { background: rgba(0, 0, 0, 0.4); border: 1px solid var(--border); padding: 0.6rem 0.8rem; border-radius: 8px; font-family: monospace; font-size: 0.78rem; word-break: break-all; color: var(--accent); margin-bottom: 0.8rem; }

.deposit-note { font-size: 0.78rem; color: var(--text-dim); background: rgba(245, 158, 11, 0.08); border: 1px solid rgba(245, 158, 11, 0.2); padding: 0.6rem 0.8rem; border-radius: 8px; margin-top: 0.8rem; display: flex; align-items: flex-start; gap: 0.4rem; }

.deposit-note i { color: var(--accent2); flex-shrink: 0; margin-top: 1px; }

.bank-details { margin: 1rem 0px; }

.bank-row { display: flex; justify-content: space-between; align-items: center; padding: 0.6rem 0px; border-bottom: 1px solid var(--border); font-size: 0.88rem; }

.bank-row span { color: var(--text-muted); }

.bank-row strong { color: var(--text); }

.fee-breakdown { margin: 1rem 0px; }

.fee-row { display: flex; justify-content: space-between; padding: 0.4rem 0px; font-size: 0.85rem; color: var(--text-muted); }

.fee-row.total { color: var(--text); font-weight: 700; border-top: 1px solid var(--border); margin-top: 0.4rem; padding-top: 0.8rem; }

.table-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem; }

.table-header h3 { font-size: 1rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem; }

.table-header select { background: var(--bg-card); border: 1px solid var(--border); color: var(--text); padding: 0.4rem 0.8rem; border-radius: 8px; font-size: 0.82rem; }

.tx-table-wrapper { overflow-x: auto; }

.tx-table { width: 100%; border-collapse: collapse; font-size: 0.83rem; }

.tx-table th { text-align: left; padding: 0.75rem 1rem; color: var(--text-dim); font-weight: 600; letter-spacing: 0.5px; font-size: 0.75rem; text-transform: uppercase; border-bottom: 1px solid var(--border); }

.tx-table td { padding: 0.85rem 1rem; border-bottom: 1px solid rgba(255, 255, 255, 0.04); color: var(--text-muted); }

.tx-table tbody tr:hover td { background: var(--bg-card-hover); }

.empty-state { text-align: center; color: var(--text-dim); padding: 3rem 1rem !important; }

.security-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }

.security-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.7rem; display: flex; align-items: center; gap: 0.5rem; }

.security-card p { color: var(--text-muted); font-size: 0.87rem; margin-bottom: 1.2rem; }

.full-width.security-card { grid-column: 1 / -1; }

.seed-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; margin-top: 1rem; }

.seed-word { background: rgba(0, 0, 0, 0.3); border: 1px solid var(--border); border-radius: 8px; padding: 0.5rem; text-align: center; font-size: 0.82rem; }

.seed-word span { font-size: 0.65rem; color: var(--text-dim); display: block; }

.seed-word strong { color: var(--accent); }

.pk-display { background: rgba(0, 0, 0, 0.4); border: 1px solid var(--border); border-radius: 8px; padding: 0.8rem; font-family: monospace; font-size: 0.78rem; word-break: break-all; color: var(--accent); margin: 0.8rem 0px; }

.warning-box { background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.25); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.82rem; color: rgb(252, 165, 165); display: flex; align-items: flex-start; gap: 0.5rem; margin-top: 1rem; }

.warning-box i { color: var(--red); flex-shrink: 0; }

.trade-layout { display: grid; grid-template-columns: 1fr 380px; gap: 1.5rem; }

